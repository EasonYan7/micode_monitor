{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiCode Monitor",
  "version": "0.7.40",
  "identifier": "com.dimillian.micodemonitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "MiCode Monitor",
        "width": 1200,
        "height": 700,
        "minWidth": 360,
        "minHeight": 600,
        "dragDropEnabled": true,
        "titleBarStyle": "Visible",
        "hiddenTitle": false,
        "transparent": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/EasonYan7/micode_monitor/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk0RjNFMkU0QjZENDY1MjUKUldRbFpkUzI1T0x6bEV4NG1Wbk5Ha01uNVEwY0psTTBlNHNLVkxDSldCa2t6RmducWZiVWNEa28K"
    }
  }
}
